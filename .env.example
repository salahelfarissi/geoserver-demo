# GeoServer image tag
GEOSERVER_TAG=2.28.3

# Path to the GeoServer data directory (bind-mounted into the container)
DATA_DIR=./geoserver_data

# Skip loading sample data on first startup
SKIP_DEMO_DATA=true

# Extension installation
INSTALL_EXTENSIONS=true
STABLE_EXTENSIONS=
COMMUNITY_EXTENSIONS=sec-oidc

# Community plugin base URL
COMMUNITY_PLUGIN_URL=https://build.geoserver.org/geoserver/2.28.x/community-latest
